{
  "name": "rk-wallet",
  "version": "1.0.0",
  "description": "RK Wallet - Rotating Kings Wallet for TKM Chain",
  "author": "RK Wallet Team",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "vite build",
    "dist:windows": "npm run build && electron-builder --win --x64",
    "dist:linux": "npm run build && electron-builder --linux --x64",
    "dist:mac": "npm run build && electron-builder --mac --x64"
  },
  "dependencies": {
    "ethers": "^5.7.2",
    "qrcode.react": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "terser": "^5.27.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.rkwallet.app",
    "productName": "RK Wallet",
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "!node_modules/.cache",
      "!**/*.map",
      "!**/*.md"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Finance"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.finance"
    }
  }
}
